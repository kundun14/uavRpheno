intersections <- st_intersection(
line_layer,
poly_layer %>% select(poly_attr = all_of(poly_label_col))
)
if (nrow(intersections) == 0) {
message("No intersections detected.")
return(NULL)
}
intersections <- st_cast(intersections, "LINESTRING")
coords <- intersections %>%
st_coordinates() %>%
as.data.frame() %>%
group_by(L1) %>%
summarise(
X_start = first(X),
Y_start = first(Y),
X_end = last(X),
Y_end = last(Y),
.groups = "drop"
)
intersections_with_coords <- bind_cols(
intersections,
coords %>% select(-L1)
)
results <- intersections_with_coords %>%
mutate(seg_len = as.numeric(st_length(geom))) %>%
st_drop_geometry() %>%
group_by(tmp_id, poly_attr, X_I, Y_I, X_F, Y_F) %>%
summarise(
total_segment_m = sum(seg_len, na.rm = TRUE),
.groups = "drop"
) %>%
left_join(st_drop_geometry(line_layer) %>% select(tmp_id, original_id = all_of(line_id_col)), by = "tmp_id") %>%
rename(
!!prefix := poly_attr,
!!paste0(prefix, "_len_m") := total_segment_m,
UID = original_id
) %>%
select(UID, !!prefix, !!paste0(prefix, "_len_m"), X_I, Y_I, X_F, Y_F)
return(results)
}
cc_results <- analyze_spatial_overlap(
line_layer     = lineas,
poly_layer     = cc,
line_id_col    = "id",     # The ID from 'lineas'
poly_label_col = "nombre", # The name of the community from 'cc'
prefix         = "COMU"    # How you want the output columns named
)
analyze_spatial_overlap <- function(line_layer, poly_layer, line_id_col, poly_label_col, prefix) {
if (st_crs(line_layer) != st_crs(poly_layer)) {
poly_layer <- st_transform(poly_layer, st_crs(line_layer))
}
line_layer <- line_layer %>%
mutate(tmp_id = row_number())
intersections <- st_intersection(
line_layer,
poly_layer %>% select(poly_attr = all_of(poly_label_col))
)
if (nrow(intersections) == 0) {
message("No intersections detected.")
return(NULL)
}
intersections <- st_cast(intersections, "LINESTRING")
coords <- intersections %>%
st_coordinates() %>%
as.data.frame() %>%
group_by(L1) %>%
summarise(
X_I = first(X),
Y_I = first(Y),
X_F = last(X),
Y_F = last(Y),
.groups = "drop"
)
intersections_with_coords <- bind_cols(
intersections,
coords %>% select(-L1)
)
results <- intersections_with_coords %>%
mutate(seg_len = as.numeric(st_length(geom))) %>%
st_drop_geometry() %>%
group_by(tmp_id, poly_attr, X_I, Y_I, X_F, Y_F) %>%
summarise(
total_segment_m = sum(seg_len, na.rm = TRUE),
.groups = "drop"
) %>%
left_join(st_drop_geometry(line_layer) %>% select(tmp_id, original_id = all_of(line_id_col)), by = "tmp_id") %>%
rename(
!!prefix := poly_attr,
!!paste0(prefix, "_len_m") := total_segment_m,
UID = original_id
) %>%
select(UID, !!prefix, !!paste0(prefix, "_len_m"), X_I, Y_I, X_F, Y_F)
return(results)
}
