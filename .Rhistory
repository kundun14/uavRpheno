enrich_pol <- function(target_pol, source_pol, col_map, inter_name) {
source_subset <- source_pol %>%
select(all_of(unname(col_map))) %>%
rename(!!col_map)
joined <- st_join(target_pol, source_subset, join = st_intersects, left = TRUE)
check_col <- names(col_map)[1]
joined <- joined %>%
mutate(!!inter_name := if_else(is.na(!!sym(check_col)), 0, 1))
if(nrow(joined) > nrow(target_pol)) {
joined <- joined %>%
group_by(geom) %>%
slice(1) %>%
ungroup()
}
return(joined)
}
